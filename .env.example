# J.A.R.V.I.S. Environment Configuration

# Ollama Connection (Change to http://host.docker.internal:11434 if running backend in Docker)
OLLAMA_BASE_URL=http://localhost:11434

# Models to use (must be pulled in Ollama)
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# Core Service API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Directory for the File Manager tool to operate inside safely (sandbox)
# On Windows, use forward slashes (e.g., C:/Users/YourName/JarvisWorkspace)
WORKSPACE_DIR=C:/Users/Hemanth/SecureJarvisBotWorkspace
